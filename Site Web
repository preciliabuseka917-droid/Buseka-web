<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>Connexion</title>
        <style>
            body {
                font-family: Arial, sans-serif;
                background: navy blue;
                height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
            }
            .login-container {
                background: black;
                padding: 70px;
                border-radius: 10px;
                box-shadow: 0px, 5px, 15px rgb(0, 0, 0, 0.2);
                width: 300px;
                text-align: center;
            }
            h2 {
                color: #eddede;
                margin-bottom: 20px;
            }
            input {
                width: 100px;
                padding: 10px;
                margin: 10px 0;
                border: 1px solid #ccc;
                border-radius: 5px;
            }
            input:focus {
                border-color: #4facfe;
                outline: none;
            }
            button {
                width: 100%;
                padding: 10px;
                background: #4facfe;
                color: white;
                border: none;
                border-radius: 5px;
                cursor: pointer;
                font-size: 16px;
            } 
            button:hover {
                background: #00c6ff;
            }
            .footer  {
            margin-top: 15px;
            font-size: 12px;
            color: #777;
            }
            .footer a {
                color: #4facfe;
                text-decoration: none;
            }
        </style>
    </head>
    <body>
        <div class="login-container">
            <h2>Connexion</h2>
            <form>
                <input type="email" placeholder="Email" required>
                <input type="password" placeholder="Mot de passe" required>
                <button type="submit">se connecter</button>
            </form>
            <div class="footer">
                Pas de compte ? <a href="#">Inscrivez-vous</a>
            </div>
        </div>    
    </body>
</html>

<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>Gestion des étudiants</title>
        <style>
            body {
                font-family: Arial;
                background: hsla(196, 44%, 77%, 0.974);
                padding: 35PX;
            }
            h2 {
                text-align: center;
            }
            .container {
                max-width: 900px;
                margin: auto;
                background: whitesmoke;
                padding: 70px;
                border-radius: 20px;
            }
            input {
                padding: 5px;
                margin: 5px;
                width: 50%;
            }
            button {
                padding: 15px;
                margin: 35px;
                border: none;
                border-radius: 15px;
                cursor: pointer;
            }
            .add {background: black; color: white;}
            .delete{background: black; color: white;}
            .update{background: black; color: white;}
            .search{background: black; color: white;}
            table {
                width: 100%;
                margin-top: 20px;
                border-collapse: collapse;
            }
            th, td {
                border: 1px solid #ccc;
                padding: 10px;
                text-align: center;
            }
            th {
                background: #23a9e3e7;
                color: hsla(100, 9%, 93%, 0.951);
            }
        </style>
    </head>
    <body>
        <div class="container">
            <h2>INSCRIPTION DES ETUDIANTS</h2>
            <input type="text" id="nom" placeholder="Nom">
            <input type="text" id="prenom" placeholder="prénom">
            <input type="text" id="classe" placeholder="Classe">
            <br>
            <button class="add" onclick="ajouter()">Enregistre</button>
            <button class="update" onclick="modifier()">Modifier</button>
            <button class="delete" onclick="supprimer()">Supprimer</button>
            <button class="search" onclick="rechercher()">Rechercher</button>
            
        </div>
    </body>
</html>


